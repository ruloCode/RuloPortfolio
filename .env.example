# This file is a placeholder for environment variables required to run this project.
# Currently, there are no environment variables needed.

# Example of what future variables might look like:
# NEXT_PUBLIC_API_KEY=your_api_key_here
# DATABASE_URL=your_database_url_here
# SECRET_KEY=your_secret_key_here

# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=password

# Waitlist (AI Shift Challenge) — signups are stored in the `waitlist`
# table in Supabase. Until these are set, /api/waitlist responds 503 and
# the form shows the error state: do NOT drive traffic to the waitlist
# before configuring them. Get the secret key (sb_secret_...) at
# https://supabase.com/dashboard/project/_/settings/api-keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_key

# Welcome email + audience sync via https://resend.com (both optional:
# without them the signup still works, it just skips the email).
# WAITLIST_FROM_EMAIL must be a sender on a domain verified in Resend,
# e.g. "Rulo <hola@tudominio.com>".
RESEND_API_KEY=re_your_api_key
WAITLIST_FROM_EMAIL=
RESEND_AUDIENCE_ID=your_audience_id

# Scheduling link for consulting CTAs (optional; falls back to Calendly).
# NEXT_PUBLIC_CAL_LINK=https://cal.com/<username>/30min
